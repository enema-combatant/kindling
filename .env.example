# Kindling — Provider Configuration
#
# Copy this file to .env and edit to match your setup:
#   cp .env.example .env
#
# See provider-guides/ for detailed setup instructions.

# ─── Provider Selection ─────────────────────────────────────────────
# Options: ollama, openai, anthropic, groq
KINDLING_PROVIDER=ollama

# ─── Model Selection ────────────────────────────────────────────────
# The chat/completion model. Examples by provider:
#   ollama:    llama3.2:3b, llama3.2:1b, qwen3:4b, mistral:7b
#   openai:    gpt-4o-mini, gpt-4o
#   anthropic: claude-sonnet-4-20250514
#   groq:      llama-3.3-70b-versatile, llama-3.1-8b-instant
KINDLING_MODEL=llama3.2:3b

# The embedding model (used in missions 01+). Examples by provider:
#   ollama:    nomic-embed-text, all-minilm
#   openai:    text-embedding-3-small, text-embedding-3-large
#   anthropic: (not available — falls back to Ollama for embeddings)
#   groq:      (not available — falls back to Ollama for embeddings)
KINDLING_EMBED_MODEL=nomic-embed-text

# ─── API Keys (cloud providers only) ───────────────────────────────
# Uncomment and fill in for your chosen provider:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...

# ─── Ollama Configuration (local provider) ──────────────────────────
# URL of your Ollama instance. Default works with Docker Compose.
OLLAMA_BASE_URL=http://ollama:11434

# ─── Advanced ───────────────────────────────────────────────────────
# Temperature for chat completions (0.0 = deterministic, 1.0 = creative)
KINDLING_TEMPERATURE=0.7

# Maximum tokens in response
KINDLING_MAX_TOKENS=2048

# ChromaDB path (missions 01-04)
CHROMA_PATH=/data/chromadb
